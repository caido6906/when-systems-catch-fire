{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Arvin-liu/when-systems-catch-fire/data/schemas/function.schema.json",
  "title": "Ignition Function",
  "type": "object",
  "required": [
    "id",
    "normalized_id",
    "slug",
    "type",
    "status",
    "language",
    "title",
    "short_definition",
    "formal_expression",
    "mechanism",
    "derived_from",
    "derives",
    "answers_questions",
    "related_cases",
    "source_notes",
    "novelty",
    "attribution",
    "license",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "normalized_id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "ignition_function"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "title": {
      "$ref": "#/$defs/bilingualText"
    },
    "short_definition": {
      "$ref": "#/$defs/bilingualNullableText"
    },
    "formal_expression": {
      "type": "object",
      "required": [
        "text",
        "math",
        "notes"
      ],
      "properties": {
        "text": {
          "type": [
            "string",
            "null"
          ]
        },
        "math": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "$ref": "#/$defs/bilingualNullableText"
        }
      },
      "additionalProperties": true
    },
    "mechanism": {
      "$ref": "#/$defs/bilingualNullableText"
    },
    "derived_from": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "derives": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "answers_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "question",
          "old_answer",
          "new_answer",
          "answer_status"
        ],
        "properties": {
          "question_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "question": {
            "$ref": "#/$defs/bilingualNullableText"
          },
          "old_answer": {
            "$ref": "#/$defs/bilingualNullableText"
          },
          "new_answer": {
            "$ref": "#/$defs/bilingualNullableText"
          },
          "answer_status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "related_cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "source_notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceNote"
      }
    },
    "novelty": {
      "type": "object",
      "required": [
        "claim",
        "search_status",
        "notes"
      ],
      "properties": {
        "claim": {
          "$ref": "#/$defs/bilingualNullableText"
        },
        "search_status": {
          "enum": [
            "not_searched",
            "no_prior_match_found",
            "partial_overlap_found",
            "known_in_literature"
          ]
        },
        "notes": {
          "$ref": "#/$defs/bilingualNullableText"
        }
      },
      "additionalProperties": true
    },
    "attribution": {
      "type": "object",
      "required": [
        "discoverer",
        "co_reasoning",
        "maintainer"
      ],
      "properties": {
        "discoverer": {
          "type": "string"
        },
        "co_reasoning": {
          "type": "string"
        },
        "maintainer": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "license": {
      "const": "CC-BY-NC-4.0"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "bilingualText": {
      "type": "object",
      "required": [
        "zh",
        "en"
      ],
      "properties": {
        "zh": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "bilingualNullableText": {
      "type": "object",
      "required": [
        "zh",
        "en"
      ],
      "properties": {
        "zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": [
        "type",
        "id",
        "path",
        "relation"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "relation": {
          "type": "string"
        },
        "unresolved": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "sourceNote": {
      "type": "object",
      "required": [
        "note_id",
        "title",
        "path",
        "quote_range"
      ],
      "properties": {
        "note_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "quote_range": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
