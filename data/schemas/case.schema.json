{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Arvin-liu/when-systems-catch-fire/data/schemas/case.schema.json",
  "title": "Ignition Case",
  "type": "object",
  "required": [
    "id",
    "slug",
    "type",
    "status",
    "language",
    "title",
    "summary",
    "case_type",
    "related_functions",
    "source_notes",
    "evidence_level",
    "license",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "ignition_case"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "title": {
      "type": "object",
      "required": [
        "zh",
        "en"
      ],
      "properties": {
        "zh": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "$ref": "#/$defs/bilingualNullableText"
    },
    "case_type": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "related_functions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relation"
      }
    },
    "source_notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceNote"
      }
    },
    "evidence_level": {
      "enum": [
        "anecdotal",
        "textual",
        "argued",
        "externally_checked",
        "unknown"
      ]
    },
    "license": {
      "const": "CC-BY-NC-4.0"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true,
  "$defs": {
    "bilingualNullableText": {
      "type": "object",
      "required": [
        "zh",
        "en"
      ],
      "properties": {
        "zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": [
        "function_id",
        "path",
        "relation"
      ],
      "properties": {
        "function_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "relation": {
          "type": "string"
        },
        "unresolved": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "sourceNote": {
      "type": "object",
      "required": [
        "note_id",
        "title",
        "path"
      ],
      "properties": {
        "note_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
